#!/bin/bash
# soma-user-useradd — crea usuario Linux para un humano (no agente)
# Usage: soma-user-useradd <user-id> <org-id> [teams]
# Requiere: root o sudo
set -eu

USER_ID="${1:-}"
ORG_ID="${2:-}"
TEAMS="${3:-}"

if [ -z "$USER_ID" ] || [ -z "$ORG_ID" ]; then
  echo "Usage: soma-user-useradd <user-id> <org-id> [teams]" >&2
  exit 1
fi

USERNAME="user-${USER_ID:0:12}"
HOMEDIR="/home/${USERNAME}"
SHELL="/bin/bash"

echo "👤 Creating user: $USERNAME"
echo "   Home: $HOMEDIR"
echo "   Org:  $ORG_ID"
echo ""

if [ -f /etc/alpine-release ]; then
  IS_ALPINE=true
else
  IS_ALPINE=false
fi

# 1. Grupo primario
if ! getent group "$USERNAME" >/dev/null 2>&1; then
  if [ "$IS_ALPINE" = true ]; then addgroup "$USERNAME"; else groupadd --force "$USERNAME"; fi
  echo "   ✅ Group: $USERNAME"
else
  echo "   ⚠️  Group $USERNAME already exists"
fi

# 2. Usuario
if id "$USERNAME" >/dev/null 2>&1; then
  echo "   ⚠️  User $USERNAME already exists (uid=$(id -u "$USERNAME"))"
else
  if [ "$IS_ALPINE" = true ]; then
    adduser -D -s "$SHELL" -h "$HOMEDIR" -G "$USERNAME" "$USERNAME"
  else
    useradd --home-dir "$HOMEDIR" --shell "$SHELL" --gid "$USERNAME" --create-home "$USERNAME"
  fi
  echo "   ✅ User created: uid=$(id -u "$USERNAME")"
fi

# 3. Grupos adicionales
_add_group() { if [ "$IS_ALPINE" = true ]; then addgroup "$1" 2>/dev/null || true; else groupadd --force "$1" 2>/dev/null || true; fi; }
_add_user_to_group() { if [ "$IS_ALPINE" = true ]; then addgroup "$1" "$2" 2>/dev/null || true; else usermod -aG "$2" "$1" 2>/dev/null || true; fi; }

_add_group "org-${ORG_ID}"
_add_user_to_group "$USERNAME" "org-${ORG_ID}"

if [ -n "$TEAMS" ]; then
  for team in $(echo "$TEAMS" | tr ',' ' '); do
    _add_group "team-${team}"
    _add_user_to_group "$USERNAME" "team-${team}"
  done
fi

echo "   ✅ Groups: $(groups "$USERNAME" | cut -d: -f2)"

# 4. Subdirectorios
mkdir -p "$HOMEDIR/workspace"
mkdir -p "$HOMEDIR/.config"

# 5. Permisos
chown -R "$USERNAME:$USERNAME" "$HOMEDIR"
chmod 700 "$HOMEDIR"
chmod 700 "$HOMEDIR/workspace"

PERM_INFO=$(stat -c '%a %U:%G' "$HOMEDIR" 2>/dev/null || stat -f '%A %Su:%Sg' "$HOMEDIR")
echo "   ✅ Permissions: $PERM_INFO"

UID_VAL=$(id -u "$USERNAME" 2>/dev/null || echo '?')
GRP_VAL=$(groups "$USERNAME" 2>/dev/null | cut -d: -f2 || echo '?')

echo ""
echo "✅ User ready: $USERNAME"
echo "   uid=$UID_VAL home=$HOMEDIR groups=$GRP_VAL"
