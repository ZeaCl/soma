#!/bin/bash
# soma-agent-useradd — crea usuario Linux para un agente
# Usage: soma-agent-useradd <agent-id> <org-id> [teams] [mounts-json]
# Requiere: root o sudo, SYS_ADMIN cap para mount --bind

set -eu

AGENT_ID="${1:-}"
ORG_ID="${2:-}"
TEAMS="${3:-}"
MOUNTS_JSON="${4:-[]}"

if [ -z "$AGENT_ID" ] || [ -z "$ORG_ID" ]; then
  echo "Usage: soma-agent-useradd <agent-id> <org-id> [teams] [mounts-json]" >&2
  exit 1
fi

USERNAME="soma-${AGENT_ID:0:12}"
HOMEDIR="/home/soma/${AGENT_ID}"
SHELL="/bin/bash"
BOOTSTRAP="/home/soma/_bootstrap"

echo "👤 Creating agent user: $USERNAME"
echo "   Home: $HOMEDIR"
echo "   Org:  $ORG_ID"
echo ""

# ── Detect Alpine vs GNU ──────────────────────────────────────────
if [ -f /etc/alpine-release ]; then
  IS_ALPINE=true
else
  IS_ALPINE=false
fi

# ── 1. Crear grupo primario ──────────────────────────────────────────
if ! getent group "$USERNAME" >/dev/null 2>&1; then
  if [ "$IS_ALPINE" = true ]; then addgroup "$USERNAME"; else groupadd --force "$USERNAME"; fi
  echo "   ✅ Group: $USERNAME"
else
  echo "   ⚠️  Group $USERNAME already exists — reusing"
fi

# ── 2. Crear usuario ─────────────────────────────────────────────────
if id "$USERNAME" >/dev/null 2>&1; then
  echo "   ⚠️  User $USERNAME already exists (uid=$(id -u "$USERNAME")) — reusing"
else
  if [ "$IS_ALPINE" = true ]; then
    adduser -D -s "$SHELL" -h "$HOMEDIR" -G "$USERNAME" "$USERNAME"
  else
    useradd --home-dir "$HOMEDIR" --shell "$SHELL" --gid "$USERNAME" --no-create-home "$USERNAME"
  fi
  echo "   ✅ User created: uid=$(id -u "$USERNAME")"
fi

# ── 3. Agregar a grupos ──────────────────────────────────────────────
_add_group() { if [ "$IS_ALPINE" = true ]; then addgroup "$1" 2>/dev/null || true; else groupadd --force "$1" 2>/dev/null || true; fi; }
_add_user_to_group() { if [ "$IS_ALPINE" = true ]; then addgroup "$1" "$2" 2>/dev/null || true; else usermod -aG "$2" "$1" 2>/dev/null || true; fi; }

_add_group soma-agents
_add_user_to_group "$USERNAME" soma-agents

_add_group "org-${ORG_ID}"
_add_user_to_group "$USERNAME" "org-${ORG_ID}"

if [ -n "$TEAMS" ]; then
  for team in $(echo "$TEAMS" | tr ',' ' '); do
    _add_group "team-${team}"
    _add_user_to_group "$USERNAME" "team-${team}"
  done
fi

echo "   ✅ Groups: $(groups "$USERNAME" | cut -d: -f2)"

# ── 4. Crear home directory ───────────────────────────────────────────
mkdir -p "$HOMEDIR/workspace"
mkdir -p "$HOMEDIR/.config"
mkdir -p "$HOMEDIR/.pi-sessions"
[ -d "$BOOTSTRAP" ] && cp "$BOOTSTRAP/.bashrc" "$HOMEDIR/" 2>/dev/null || true
[ -d "$BOOTSTRAP" ] && cp "$BOOTSTRAP/.gitconfig" "$HOMEDIR/" 2>/dev/null || true

# ── 5. Permisos ──────────────────────────────────────────────────────
chown -R "$USERNAME:$USERNAME" "$HOMEDIR"
chmod 700 "$HOMEDIR"
chmod 700 "$HOMEDIR/workspace"
echo "   ✅ Permissions: $(stat -c '%a %U:%G' "$HOMEDIR" 2>/dev/null || stat -f '%A %Su:%Sg' "$HOMEDIR")"

# ── 6. Montar volúmenes compartidos (bash puro, sin python) ──────────
_mount_bind() {
  local src="$1" dst="$2" ro="$3"
  [ ! -d "$src" ] && { echo "   ⚠️  Source not found: $src — skipping"; return; }
  mkdir -p "$dst"
  if mount --bind "$src" "$dst" 2>/dev/null; then
    if [ "$ro" = "true" ]; then
      if mount -o remount,ro,bind "$dst" 2>/dev/null; then
        echo "   ✅ Mount: $src → $dst (ro)"
      else
        # overlayfs fallback: ensure source is not writable by agent users
        echo "   ⚠️  Mount: $src → $dst (rw, remount ro not supported on this fs)"
        echo "   → Ensure source permissions prevent writes (chown root:root $src)"
      fi
    else
      echo "   ✅ Mount: $src → $dst (rw)"
    fi
  else
    echo "   ⚠️  Mount failed: $src"
  fi
}

if [ -n "$MOUNTS_JSON" ] && [ "$MOUNTS_JSON" != "[]" ]; then
  echo "   Processing mounts..."
  # Parse simple JSON array of {source, dest, ro} objects
  echo "$MOUNTS_JSON" | tr '}' '\n' | while read -r chunk; do
    src=$(echo "$chunk" | sed -n 's/.*"source"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p')
    dst=$(echo "$chunk" | sed -n 's/.*"dest"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p')
    ro=$(echo "$chunk" | grep -q '"ro"[[:space:]]*:[[:space:]]*true' && echo "true" || echo "false")
    [ -n "$src" ] && _mount_bind "$src" "$HOMEDIR/${dst:-shared}" "$ro"
  done
fi

echo ""
echo "✅ Agent user ready: $USERNAME"
echo "   uid=$(id -u "$USERNAME" 2>/dev/null || echo '?')" home=$HOMEDIR groups="$(groups "$USERNAME" 2>/dev/null | cut -d: -f2 || echo '?')"
